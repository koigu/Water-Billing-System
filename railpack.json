{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "caches": {
    "npm": {
      "directory": "/root/.npm",
      "type": "shared"
    },
    "pip": {
      "directory": "/root/.cache/pip",
      "type": "shared"
    }
  },
  "steps": {
    "frontend-build": {
      "caches": ["npm"],
      "commands": [
        {
          "cmd": "cd frontend && npm ci",
          "customName": "Install frontend deps"
        },
        {
          "cmd": "cd frontend && npm run build",
          "customName": "Build frontend"
        }
      ]
    },
    "backend-deps": {
      "caches": ["pip"],
      "commands": [
        {
          "cmd": "pip install -r requirements.txt",
          "customName": "Install backend deps from requirements.txt"
        }
      ]
    },
    "copy-frontend": {
      "commands": [
        {
          "cmd": "cp -r frontend/dist/* static/",
          "customName": "Copy frontend build to static"
        }
      ]
    }
  },
  "deploy": {
    "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port $PORT",
    "paths": [
      "node_modules/.bin"
    ],
    "inputs": [
      {
        "step": "frontend-build"
      },
      {
        "step": "backend-deps"
      },
      {
        "step": "copy-frontend"
      }
    ]
  }
}
