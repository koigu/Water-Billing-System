# =============================================================================
# Water Billing System - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values

# ==================== APPLICATION SETTINGS ====================
FLASK_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# ==================== DATABASE SETTINGS ====================
# SQLite (default for development)
DATABASE_URL=sqlite:///water_billing.db

# MongoDB (optional, for multi-tenant setup)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=water_billing

# ==================== NOTIFICATION PROVIDER SETTINGS ====================

# Primary SMS Provider (defaults to africas_talking)
# SMS_PROVIDER=africas_talking

# Fallback SMS Provider (optional)
# SMS_FALLBACK_PROVIDER=

# ==================== AFRICA'S TALKING CONFIGURATION ====================
# Get credentials from: https://account.africastalking.com
# Africa's Talking is a leading SMS provider in Africa
AFRICAS_TALKING_API_KEY=your_africas_talking_api_key
AFRICAS_TALKING_USERNAME=your_africas_talking_username
# Set to false when going to production
AFRICAS_TALKING_IS_SANDBOX=true
# Enable if your account supports WhatsApp
AFRICAS_TALKING_SUPPORTS_WHATSAPP=false

# ==================== EMAIL CONFIGURATION (SMTP) ====================
# Configure for sending email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
# Use an App Password for Gmail: https://support.google.com/accounts/answer/185833
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@waterbilling.com

# ==================== JWT SETTINGS ====================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
TOKEN_EXPIRE_HOURS=24

# ==================== MULTI-TENANT SETTINGS ====================
# For multi-tenant deployment
MASTER_DATABASE_NAME=water_billing_master
DEFAULT_PROVIDER_LIMIT=100

# ==================== RATE LIMITING ====================
# Rate limits per minute
SMS_RATE_LIMIT=100
EMAIL_RATE_LIMIT=50

# ==================== EXTERNAL SERVICES ====================
# Payment Gateway (example: M-Pesa)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=

