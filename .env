# Database (SQLite)
DATABASE_URL=mongodb://localhost:27017/waterbilling

# App
APP_HOST=127.0.0.1
APP_PORT=8000

# Billing
RATE_PER_UNIT=1.5

# Email (SMTP) - fill these if you want email sending
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=changeme
FROM_EMAIL=you@example.com

# Twilio (optional) for SMS/WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Example SMS: +15551234567
# Example WhatsApp: whatsapp:+15551234567
TWILIO_FROM_NUMBER=whatsapp:+1415...  # or SMS number
TWILIO_MESSAGING_SERVICE_SID=

# Admin (for rate changes)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
# Session secret for cookie sessions (use strong random value)
SECRET_KEY=please_change_this_to_a_random_value